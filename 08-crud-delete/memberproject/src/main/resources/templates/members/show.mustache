{{>layouts/header}}

<table class="table">
    <thead class="table-header">
    <tr>
        <th>Id</th>
        <th>Email</th>
        <th>Password</th>
    </tr>
    </thead>

    <tbody>
    {{#member}}
        <tr>
            <td>{{id}}</td>
            <td>{{email}}</td>
            <td>{{password}}</td>
        </tr>
    {{/member}}
    </tbody>
</table>

<a href="/members/{{member.id}}/edit" class="btn btn-primary">수정하기</a>
<a href="/members/{{member.id}}/delete" class="btn btn-primary">삭제하기</a>
<a href="/members">Go to member list</a>

{{>layouts/footer}}