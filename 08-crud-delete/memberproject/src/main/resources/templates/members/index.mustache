{{>layouts/header}}

<table class="table">
    <thead class="table-header">
    <tr>
        <th>Id</th>
        <th>Email</th>
        <th>Password</th>
    </tr>
    </thead>

    <tbody>
    {{#members}}
        <tr>
            <td>{{id}}</td>
            <td><a href="/members/{{id}}">{{email}}</a></td>
            <td>{{password}}</td>
        </tr>
    {{/members}}
    </tbody>
</table>

<a href="/members/new">회원 가입</a>

{{>layouts/footer}}