{{>layouts/header}}
<table class="table">
    <thead>
    <tr><th>Id</th><th>Title</th><th>Content</th></tr>
    </thead>
    <tbody>

    <!--상세 보기 링크 (제목에 링크 걸기)-->
    <!-- <a href="/articles/1">제목</a> -->
    {{#article}}
        <tr><th>{{id}}</th><td><a href="/articles/{{id}}">{{title}}</td><td>{{content}}</td></tr>
    {{/article}}
    </tbody>
</table>

<!--입력페이지 링크-->
<a href="/articles/new">새 글쓰기</a>
{{>layouts/footer}}